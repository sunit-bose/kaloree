rules_version = '2';

// Firestore Security Rules for Kaloree
// 
// CRITICAL: These rules ensure:
// - Users can only access their own data
// - No cross-user data access
// - No open rules that could expose data
//
// Structure:
// users/{uid}/daily/{YYYY-MM-DD}/entries/{entryId}

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // USER DATA RULES
    // ============================================
    
    // User document - profile data
    match /users/{userId} {
      // Allow read/write only if authenticated and accessing own data
      allow read, write: if request.auth != null 
                         && request.auth.uid == userId;
      
      // Daily logs collection
      match /daily/{dayId} {
        // Allow read/write only if authenticated and accessing own data
        allow read, write: if request.auth != null 
                           && request.auth.uid == userId;
        
        // Food entries for each day
        match /entries/{entryId} {
          // Allow read/write only if authenticated and accessing own data
          allow read, write: if request.auth != null 
                             && request.auth.uid == userId;
        }
      }
      
      // Favorites collection (if stored separately)
      match /favorites/{favoriteId} {
        allow read, write: if request.auth != null 
                           && request.auth.uid == userId;
      }
      
      // Custom foods collection
      match /custom_foods/{foodId} {
        allow read, write: if request.auth != null 
                           && request.auth.uid == userId;
      }
      
      // Goals and settings
      match /settings/{settingId} {
        allow read, write: if request.auth != null 
                           && request.auth.uid == userId;
      }
    }
    
    // ============================================
    // SHARED DATA RULES (Read-only for all authenticated users)
    // ============================================
    
    // Shared food database (if any)
    match /foods/{foodId} {
      // All authenticated users can read
      allow read: if request.auth != null;
      // Only admin can write (handled by admin SDK)
      allow write: if false;
    }
    
    // App config/announcements
    match /app_config/{configId} {
      // All authenticated users can read
      allow read: if request.auth != null;
      // Only admin can write
      allow write: if false;
    }
    
    // ============================================
    // DEFAULT DENY
    // ============================================
    
    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
